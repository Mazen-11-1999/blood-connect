# نسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
PORT=3000
NODE_ENV=development

# سر توقيع JWT — فقط على الخادم، لا تضعه في JavaScript الواجهة. في الإنتاج: 32 حرفاً على الأقل
# JWT_SECRET=

# اتركه فارغاً لاستخدام data/app-data.json محلياً
# أو ضع رابط PostgreSQL لتفعيل قاعدة البيانات الحقيقية:

# صور الملف الشخصي: إذا وُجد DATABASE_URL ولم تُضبط CLOUDINARY_URL تُحفظ الصور داخل PostgreSQL (دائمة مع قاعدة البيانات).
# الأولوية: Cloudinary إن وُجد CLOUDINARY_URL ← ثم PostgreSQL ← ثم مجلد uploads محلياً فقط.

# هدف التسجيلات الشهرية لبطاقة التوعية (الواجهة الرئيسية) — النسبة تُحسب من متبرعي الشهر الحالي
# AWARENESS_MONTHLY_GOAL=500

# Render Postgres / أغلب السحاب: إذا فشل الاتصال جرّب:
# PGSSLMODE=require

# في الإنتاج: قائمة نطاقات مسموحة مفصولة بفواصل (اختياري)
# CORS_ORIGINS=https://example.com,https://www.example.com
# NODE_ENV=production
# إطلاق حقيقي: استخدم HTTPS (Render/Railway/VPS). PWA يتطلب HTTPS عدا localhost.
# صفحة /qr.html تعرض رمز QR للرابط — بعد النشر ضع نطاقك في حقل الرابط أو ?url=https://نطاقك/

# Twilio (اختياري)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Cloudinary — تخزين دائم لصور الملف الشخصي (مجاني ضمن الحصة). أنشئ حساباً مجانياً على https://cloudinary.com
# ثم من Dashboard → API Keys انسخ السطر الكامل:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# اختياري: مجلد الصور على السحابة (افتراضي inqadh-hayah/avatars)
# CLOUDINARY_AVATAR_FOLDER=inqadh-hayah/avatars

# Web Push — إشعار المستلم عند وصول رسالة (يتطلب HTTPS). أنشئ المفاتيح: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:بريدك@example.com
